PORT=8001

# Profile: dev (PostgreSQL local, mặc định) | prod (PostgreSQL bắt buộc)
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL — dev & prod (chạy local: docker compose up -d trong sit-api/)
DB_URL=jdbc:postgresql://localhost:5434/sit_vnpay_db
DB_USERNAME=postgres
DB_PASSWORD=sit123456
# DB_HOST=localhost
# DB_PORT=5434
# DB_NAME=sit_vnpay_db
# DB_JDBC_PARAMS=?sslmode=disable

SIT_TIMEOUT_MS=15000
SIT_SIMULATE_VNPAY_IP=true
SIT_CORS_ORIGINS=http://localhost:8000

# Render: bật CORS cho mọi subdomain *.onrender.com (xem render.yaml)
# SIT_CORS_ALLOW_ONRENDER=true

# Bắt buộc — JWT ký token (tối thiểu 32 ký tự, đổi khi deploy)
SIT_JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
SIT_JWT_EXPIRATION_MS=86400000

# Tài khoản admin tự tạo lần đầu (khi DB chưa có user)
SIT_ADMIN_EMAIL=admin@vnpay.vn
SIT_ADMIN_PASSWORD=change-me-on-deploy
SIT_ADMIN_NAME=System Admin
