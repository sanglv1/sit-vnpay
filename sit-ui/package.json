{
  "name": "sit-ui",
  "version": "0.1.0",
  "private": true,
  "homepage": "/sit-ui",
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "axios": "1.5.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "7.47.0",
    "react-redux": "8.1.3",
    "react-router-dom": "6.17.0",
    "react-scripts": "5.0.1",
    "redux": "4.2.1",
    "redux-thunk": "^2.4.2"
  },
  "scripts": {
    "start": "env-cmd -f .env.dev react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --coverage",
    "test:smoke": "react-scripts test --watchAll=false --runTestsByPath src/App.smoke.test.js",
    "lint": "eslint src --ext .js,.jsx --max-warnings 0",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^13.4.0",
    "env-cmd": "^10.1.0"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/App.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 100,
        "lines": 90,
        "statements": 90
      }
    }
  }
}
